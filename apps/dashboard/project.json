{
  "name": "dashboard",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/dashboard/src",
  "targets": {
    "build": {
      "command": "cd apps/dashboard && npx vite build"
    },
    "test": {
      "command": "npx vitest run --config apps/dashboard/vitest.config.ts"
    },
    "typecheck": {
      "command": "tsc --noEmit -p apps/dashboard/tsconfig.json"
    },
    "serve": {
      "command": "cd apps/dashboard && npx vite"
    },
    "lint": {
      "command": "eslint apps/dashboard/src"
    }
  }
}
