{
  "name": "orchestrator-api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/orchestrator-api/src",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "options": {
        "outputPath": "dist/apps/orchestrator-api",
        "main": "apps/orchestrator-api/src/main.ts",
        "tsConfig": "apps/orchestrator-api/tsconfig.json",
        "rootDir": ".",
        "assets": [
          {
            "input": "apps/orchestrator-api",
            "glob": "tsconfig.runtime.json",
            "output": "."
          }
        ]
      }
    },
    "test": {
      "command": "npx vitest run --config vitest.config.ts apps/orchestrator-api"
    },
    "typecheck": {
      "command": "tsc --noEmit -p apps/orchestrator-api/tsconfig.json"
    }
  }
}
