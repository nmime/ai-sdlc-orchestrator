    "@mikro-orm/cli": "^6.4.0",
    "@mikro-orm/core": "^6.4.0",
    "@mikro-orm/migrations": "^6.4.0",
    "@mikro-orm/nestjs": "^6.1.0",
    "@mikro-orm/postgresql": "^6.4.0",
    "@mikro-orm/reflection": "^6.4.0",
    "@nestjs/common": "^11.1.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/platform-fastify": "^11.1.0",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/terminus": "^11.0.0",
    "@temporalio/activity": "^1.12.2",
    "@temporalio/client": "^1.12.2",
    "@temporalio/common": "^1.12.2",
    "@temporalio/worker": "^1.12.2",
    "@temporalio/workflow": "^1.12.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.3.1",
    "e2b": "^1.4.1",
    "fastify": "^5.3.0",
    "js-yaml": "^4.1.0",
    "neverthrow": "^8.2.0",
    "pino": "^9.7.0",
    "pino-http": "^10.4.0",
    "pino-pretty": "^13.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tslib": "^2.8.1",
    "uuid": "^11.1.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.0",
    "@nx/eslint-plugin": "^21.2.0",
    "@nx/jest": "^21.2.0",
    "@nx/js": "^21.2.0",
    "@nx/nest": "^21.2.0",
    "@nx/node": "^21.2.0",
    "@nx/react": "^21.2.0",
    "@nx/vite": "^21.2.0",
    "@nx/web": "^21.2.0",
    "@nx/webpack": "^21.2.0",
    "@nx/workspace": "^21.2.0",
    "@swc-node/register": "^1.10.10",
    "@swc/core": "^1.11.0",
    "@swc/helpers": "^0.5.19",
    "@temporalio/testing": "^1.12.2",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.0",
    "@types/uuid": "^10.0.0",
