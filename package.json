{
  "name": "opwerf",
  "version": "0.1.0",
  "description": "Opwerf – autonomous SDLC orchestration platform with multi-tenant support, automated workflows, and agent-based code generation",
  "license": "MIT",
  "author": "Opwerf Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/opwerf/opwerf.git"
  },
  "keywords": [
    "sdlc",
    "ai",
    "orchestration",
    "temporal",
    "nestjs",
    "multi-tenant",
    "devops",
    "automation"
  ],
  "bugs": {
    "url": "https://github.com/opwerf/opwerf/issues"
  },
  "homepage": "https://github.com/opwerf/opwerf#readme",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "nx run-many -t build",
    "lint": "nx run-many -t lint",
    "test": "nx run-many -t test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dev:api": "nx serve orchestrator-api",
    "dev:worker": "nx serve orchestrator-worker",
    "dev:dashboard": "nx serve dashboard",
    "db:migrate": "mikro-orm migration:up",
    "db:migrate:create": "mikro-orm migration:create",
    "db:seed": "mikro-orm seeder:run",
    "docker:up": "docker compose -f docker-compose.dev.yml up -d",
    "docker:down": "docker compose -f docker-compose.dev.yml down",
    "prepare": "nx run-many -t build --projects=tag:lib"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.83",
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/google": "^3.0.53",
    "@ai-sdk/mistral": "^3.0.27",
    "@ai-sdk/openai": "^3.0.48",
    "@ai-sdk/provider": "^3.0.8",
    "@ai-sdk/xai": "^3.0.74",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.2.0",
    "@fastify/static": "^9.0.0",
    "@mikro-orm/cli": "^6.4.0",
    "@mikro-orm/core": "^6.4.0",
    "@mikro-orm/migrations": "^6.4.0",
    "@mikro-orm/nestjs": "^6.1.0",
    "@mikro-orm/postgresql": "^6.4.0",
    "@mikro-orm/reflection": "^6.4.0",
    "@nestjs/common": "^11.1.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/platform-fastify": "^11.1.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/terminus": "^11.0.0",
    "@temporalio/activity": "^1.12.2",
    "@temporalio/client": "^1.12.2",
    "@temporalio/common": "^1.12.2",
    "@temporalio/worker": "^1.12.2",
    "@temporalio/workflow": "^1.12.2",
    "ai": "^6.0.141",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.3.1",
    "e2b": "^1.4.1",
    "fastify": "^5.8.4",
    "jose": "^6.2.2",
    "js-yaml": "^4.1.0",
    "minio": "^8.0.7",
    "neverthrow": "^8.2.0",
    "pino": "^9.7.0",
    "pino-http": "^10.4.0",
    "pino-pretty": "^13.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tslib": "^2.8.1",
    "uuid": "^11.1.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.0",
    "@nx/eslint-plugin": "^21.2.0",
    "@nx/jest": "^21.2.0",
    "@nx/js": "^21.2.0",
    "@nx/nest": "^21.2.0",
    "@nx/node": "^21.2.0",
    "@nx/react": "^22.6.3",
    "@nx/vite": "^21.2.0",
    "@nx/web": "^21.2.0",
    "@nx/workspace": "^21.2.0",
    "@swc-node/register": "^1.10.10",
    "@swc/core": "^1.11.0",
    "@swc/helpers": "^0.5.19",
    "@temporalio/testing": "^1.12.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "eslint": "^9.39.4",
    "happy-dom": "^20.8.9",
    "jest": "^29.7.0",
    "nx": "^21.2.0",
    "testcontainers": "^10.16.0",
    "ts-jest": "^29.3.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "~5.8.0",
    "typescript-eslint": "8.57.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.1"
  },
  "pnpm": {
    "overrides": {
      "minimatch": ">=9.0.7",
      "serialize-javascript": ">=7.0.3",
      "picomatch": ">=4.0.4",
      "undici": ">=6.24.0",
      "koa": ">=3.1.2",
      "fastify": ">=5.8.3",
      "@angular-devkit/core>ajv": ">=8.18.0",
      "handlebars": ">=4.7.9",
      "@nestjs/core>path-to-regexp": ">=8.4.0",
      "@nestjs/swagger>path-to-regexp": ">=8.4.0",
      "@nestjs/platform-fastify>path-to-regexp": ">=8.4.0",
      "express>path-to-regexp": ">=8.4.0",
      "@rushstack/node-core-library>ajv": ">=8.18.0"
    }
  }
}
