# ╔══════════════════════════════════════════════════════════════╗
# ║  Opwerf — Environment Configuration                         ║
# ║  Copy to .env and fill in required values marked with [REQ] ║
# ╚══════════════════════════════════════════════════════════════╝

# ─── Database (PostgreSQL) ─────────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=6432
DATABASE_NAME=orchestrator
DATABASE_USER=orchestrator
DATABASE_PASSWORD=             # [REQ] PostgreSQL password

# ─── Temporal (workflow engine) ────────────────────────────────
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default

# ─── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── MinIO / S3 (artifact storage) ────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=              # [REQ] MinIO access key
MINIO_SECRET_KEY=              # [REQ] MinIO secret key
MINIO_BUCKET=opwerf-artifacts
MINIO_USE_SSL=false

# ─── E2B Sandbox ──────────────────────────────────────────────
E2B_API_KEY=                   # [REQ] Get from https://e2b.dev/dashboard

# ─── Security ─────────────────────────────────────────────────
ENCRYPTION_KEY=                # [REQ] 32+ char encryption key
ENCRYPTION_SALT=               # [REQ] 16+ char salt
CREDENTIAL_PROXY_INTERNAL_TOKEN=  # [REQ] Internal service token

# ╔══════════════════════════════════════════════════════════════╗
# ║  AI Providers — set at least ONE to enable agent features   ║
# ╚══════════════════════════════════════════════════════════════╝

# ─── Provider Selection ───────────────────────────────────────
# Set to a specific provider name, or "auto" to detect from keys.
# Options: auto | openai | anthropic | google | mistral | xai | azure | bedrock
DEFAULT_AGENT_PROVIDER=auto
# Override default model (leave empty to use provider defaults):
# DEFAULT_AGENT_MODEL=

# ─── OpenAI ─── https://platform.openai.com/api-keys ─────────
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# ─── Anthropic (Claude) ─── https://console.anthropic.com/ ───
# Recommended: best tool-use, extended thinking, prompt caching
ANTHROPIC_API_KEY=

# ─── Google (Gemini) ─── https://aistudio.google.com/apikey ──
GOOGLE_GENERATIVE_AI_API_KEY=

# ─── Mistral ─── https://console.mistral.ai/api-keys ─────────
MISTRAL_API_KEY=

# ─── xAI (Grok) ─── https://console.x.ai/ ────────────────────
XAI_API_KEY=

# ─── Azure OpenAI ─── https://portal.azure.com ────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# ─── Amazon Bedrock ─── https://console.aws.amazon.com ────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ─── Custom OpenAI-Compatible Providers ───────────────────────
# JSON array of { name, baseURL, apiKey?, model? }
# Examples: DeepSeek, Groq, Together, Fireworks, OpenRouter, Ollama, vLLM, Perplexity, LM Studio
# AI_PROVIDER_CONFIGS='[
#   { "name": "ollama",    "baseURL": "http://localhost:11434/v1", "model": "llama3.1" },
#   { "name": "deepseek",  "baseURL": "https://api.deepseek.com/v1", "apiKey": "sk-...", "model": "deepseek-chat" },
#   { "name": "groq",      "baseURL": "https://api.groq.com/openai/v1", "apiKey": "gsk_...", "model": "llama-3.1-70b-versatile" },
#   { "name": "together",  "baseURL": "https://api.together.xyz/v1", "apiKey": "...", "model": "meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo" },
#   { "name": "fireworks", "baseURL": "https://api.fireworks.ai/inference/v1", "apiKey": "..." },
#   { "name": "openrouter","baseURL": "https://openrouter.ai/api/v1", "apiKey": "sk-or-..." },
#   { "name": "perplexity","baseURL": "https://api.perplexity.ai", "apiKey": "pplx-..." },
#   { "name": "lmstudio",  "baseURL": "http://localhost:1234/v1" },
#   { "name": "vllm",      "baseURL": "http://localhost:8000/v1" }
# ]'

# ─── Agent Settings ───────────────────────────────────────────
AGENT_MAX_TURNS=25             # Max tool-use steps per session
AGENT_MAX_DURATION_MS=3600000  # 1 hour max per session
SANDBOX_TIMEOUT_MS=600000      # 10 min sandbox timeout
BUDGET_RESERVATION_USD=50      # Max cost reservation per run

# ─── Cost Tracking ────────────────────────────────────────────
AI_INPUT_COST_PER_1M=3.0
AI_OUTPUT_COST_PER_1M=15.0
SANDBOX_COST_PER_HOUR_USD=0.05

# ─── Application Settings ────────────────────────────────────
API_PORT=3000
NODE_ENV=production
WORKER_LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute
SSE_POLL_INTERVAL_MS=5000
SANITIZER_MODE=block
